# ===========================================
# KNOTTIX — Environment Variables
# ===========================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# ---- Database ----
DATABASE_URL="postgresql://user:password@localhost:5432/knottix?schema=public"

# ---- Auth (Auth.js v5) ----
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3955"

# Google OAuth — optional alternate sign-in for existing team members only. Knottix never
# auto-creates a User from a Google sign-in; the email must already match a real, active `User`
# row (see src/lib/auth/config.ts). Leave both unset to hide the "Sign in with Google" button
# entirely. Create credentials at https://console.cloud.google.com/apis/credentials — authorized
# redirect URI is `<AUTH_URL>/api/auth/callback/google`.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---- AI Providers ----
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GOOGLE_AI_API_KEY=""

# ---- File Storage (R2 / S3) ----
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# ---- App ----
NEXT_PUBLIC_APP_URL="http://localhost:3955"
NODE_ENV="development"

# ---- Demo Mode ----
# Presentation-layer switch only — see src/lib/demo/config.ts. When "true", pages render
# DEMO_* fixture data instead of live queries, and login falls back to a synthetic Founder
# session with no database required. Leave unset/false for real usage.
NEXT_PUBLIC_DEMO_MODE="false"

# ---- Integrations ----
# AES-256-GCM key used to encrypt third-party integration credentials (e.g. the GitHub personal
# access token) before they're written to Integration.credentials. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Losing/rotating this key invalidates every stored integration credential — they'll need to be
# reconnected. See src/lib/crypto/encryption.ts and DEC-034.
INTEGRATION_ENCRYPTION_KEY="generate-with-node-crypto-randomBytes-32-base64"

# GitHub OAuth App credentials — reserved for a future OAuth connect flow (DEC-034). Not required
# today: connecting GitHub currently uses a user-supplied Personal Access Token instead.
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ---- Desktop Runtime — Voice (src/lib/desktop-runtime/voice/) ----
# Speech-to-text: Deepgram preferred if set, otherwise OpenAI Whisper (reuses OPENAI_API_KEY
# above). Neither set → voice commands fail with a clear "no STT provider configured" error,
# never a fake transcript.
DEEPGRAM_API_KEY=""
# Text-to-speech: ElevenLabs if set, otherwise falls back to Windows' built-in SAPI voice via
# PowerShell — always speaks for real, no silent no-op fallback.
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID=""
