// ============================================================================
// SKILL REGISTRY
// ============================================================================

enum SkillCategory {
  DEVELOPMENT
  BROWSER
  DESKTOP
  BUSINESS
  INTELLIGENCE
  MCP
}

/// Metadata-only, mirroring `AITool` exactly (DEC-027 point 3's precedent): a skill's plan-building
/// function is a JS closure and cannot be serialized, so only its descriptive metadata is
/// persisted here for cross-restart admin visibility and `isActive` overrides. The real
/// `SkillDefinition` (including `buildPlan`) is always registered from code first.
model Skill {
  id                 String        @id @default(uuid())
  organizationId     String?
  key                String
  name               String
  description        String
  category           SkillCategory
  requiredTools      Json
  requiredPermission String
  inputs             Json
  outputs            String
  verificationMethod String
  version            String        @default("1.0.0")
  isActive           Boolean       @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?

  @@unique([organizationId, key])
  @@index([organizationId, category])
}

// ============================================================================
// TASK SESSIONS
// ============================================================================

enum TaskSessionStatus {
  RUNNING
  PAUSED
  BLOCKED
  COMPLETED
  FAILED
  CANCELLED
}

/// A long-running autonomous goal that may span multiple Goal Execution rounds (each a real
/// `WorkflowExecution`, see `Workflow`/`WorkflowExecution` above). The session itself owns no
/// execution logic — it's a persisted wrapper tracking which `WorkflowExecution`s it has spawned
/// toward one objective, real artifacts those executions produced, and enough identity
/// (organizationId/workspaceId/createdBy) to rebuild a fresh `WorkflowContext` and resume after a
/// server restart (see `WorkflowExecutor.resume()`'s rehydration path).
model TaskSession {
  id             String            @id @default(uuid())
  organizationId String
  workspaceId    String?
  createdBy      String
  objective      String
  status         TaskSessionStatus @default(RUNNING)

  /// The `WorkflowExecution.id` currently in flight or last paused/finished — null only before
  /// the first round has run.
  currentWorkflowExecutionId String?
  /// Every `WorkflowExecution.id` this session has spawned, in order — a session can span more
  /// than one round when explicitly continued (Command Center "Continue my website").
  workflowExecutionIds Json
  /// The skill keys the most recent round composed — denormalized for the Task Sessions page so
  /// it doesn't need to re-fetch and re-parse the underlying workflow on every list render.
  skillKeys  Json
  artifacts  Json    @default("[]")
  /// The session's real Working Context (top-ranked `ContextItem[]` from the most recent round's
  /// collection pass, see `src/lib/context-engine/`) — re-collected on every `startTaskSession`/
  /// `continueTaskSession` round, so newly produced artifacts and newly completed rounds
  /// automatically feed back into what the NEXT round sees as relevant.
  workingContext Json    @default("[]")
  retryCount     Int     @default(0)
  lastError      String?

  startedAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  @@index([organizationId, status])
  @@index([organizationId, createdBy])
}

// ============================================================================
// MCP CLIENT LAYER
// ============================================================================

enum MCPTransportType {
  STDIO
  SSE
  HTTP
}

enum MCPServerStatus {
  DISCONNECTED
  CONNECTING
  CONNECTED
  ERROR
}

/// A Founder-configured external MCP server — Knottix as an MCP *client*, never a server config
/// the end user can inject arbitrary values into at request time (same trust boundary as the
/// Desktop Runtime's allowlisted dev tools: configured once, by someone with `integrations:manage`,
/// not driven by free-text goal input). `authToken` reuses the exact same AES-256-GCM envelope
/// `src/lib/crypto/encryption.ts` already established for GitHub credentials (DEC-034).
model MCPServer {
  id             String           @id @default(uuid())
  organizationId String
  name           String
  transport      MCPTransportType
  /// stdio only — the executable to spawn.
  command String?
  /// stdio only — arguments to the spawned process.
  args Json?
  /// sse/http only — the server's endpoint URL.
  url String?
  /// Encrypted `{ciphertext, iv, authTag}` envelope, present only when the server requires auth.
  authToken Json?
  isActive  Boolean @default(true)

  status              MCPServerStatus @default(DISCONNECTED)
  serverVersion       String?
  lastConnectedAt     DateTime?
  lastError           String?
  consecutiveFailures Int             @default(0)
  latencyMs           Int?
  toolCount           Int             @default(0)
  resourceCount       Int             @default(0)
  promptCount         Int             @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  callLogs MCPCallLog[]

  @@unique([organizationId, name])
  @@index([organizationId, isActive])
}

enum MCPCallType {
  TOOL
  RESOURCE
  PROMPT
}

/// Every MCP request Knottix makes, real — "log every MCP request" and "prompt usage must be
/// logged" from the same one mechanism, backing the MCP page's "Recent Calls"/"Failures" and the
/// Command Center's "why did you choose this MCP tool" explanation.
model MCPCallLog {
  id          String      @id @default(uuid())
  serverId    String
  server      MCPServer   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  type        MCPCallType
  name        String
  success     Boolean
  durationMs  Int
  error       String?
  requestedBy String?

  createdAt DateTime @default(now())

  @@index([serverId, createdAt])
}
